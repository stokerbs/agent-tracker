# ============================================================
# Detective Pulse Operations Command Center — Environment Vars
# Copy this file to `.env.local` and fill in real values.
# ============================================================

# --- Supabase ---------------------------------------------------------------
# Project URL and anon key are found in: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service-role key is SECRET. Server-side only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Google Maps ------------------------------------------------------------
# Enable "Maps JavaScript API" + "Places API" in Google Cloud Console.
# Restrict the key to your deployment domain(s).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-browser-key

# --- AI Report Generator ----------------------------------------------------
# Used by the server-side AI report endpoint. Optional — without it the
# generator falls back to a deterministic template engine.
ANTHROPIC_API_KEY=your-anthropic-api-key
AI_REPORT_MODEL=claude-sonnet-4-6

# --- PII Encryption ---------------------------------------------------------
# Required. AES-256-GCM key for encrypting target PII (name, phone, address,
# vehicle, plate). Both must be 64-character lowercase hex strings (32 bytes).
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-64-char-hex-encryption-key
BIDX_KEY=your-64-char-hex-blind-index-key

# --- App --------------------------------------------------------------------
# REQUIRED in production. Set to your Vercel deployment URL (or custom domain).
# Used as the base URL in Supabase email confirmation links (emailRedirectTo).
# Example: https://your-app.vercel.app  or  https://app.detectivepulse.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
