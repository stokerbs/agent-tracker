# ============================================================
# Detective Pulse Operations Command Center — Environment Vars
# Copy this file to `.env.local` and fill in real values.
# ============================================================

# --- Supabase ---------------------------------------------------------------
# Project URL and anon key are found in: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service-role key is SECRET. Server-side only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Google Maps ------------------------------------------------------------
# Enable "Maps JavaScript API" + "Places API" in Google Cloud Console.
# Restrict the key to your deployment domain(s).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-browser-key
# Map ID from Google Cloud Console → Maps Platform → Map Management (required for AdvancedMarker)
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=your-map-id

# --- AI Report Generator ----------------------------------------------------
# Used by the server-side AI report endpoint. Optional — without it the
# generator falls back to a deterministic template engine.
ANTHROPIC_API_KEY=your-anthropic-api-key
AI_REPORT_MODEL=claude-sonnet-4-6

# --- PII Encryption ---------------------------------------------------------
# Required. AES-256-GCM key for encrypting target PII (name, phone, address,
# vehicle, plate). Both must be 64-character lowercase hex strings (32 bytes).
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-64-char-hex-encryption-key
BIDX_KEY=your-64-char-hex-blind-index-key

# --- Email (Resend) ---------------------------------------------------------
# Get your API key at https://resend.com — free tier covers 3 000 emails/month.
# Without this key, emails are silently skipped (no error thrown).
RESEND_API_KEY=re_your_resend_api_key

# "From" address shown to recipients. Must use a domain verified in Resend.
# Defaults to: Detective Pulse <no-reply@detectivepulse.app>
# EMAIL_FROM=Detective Pulse <no-reply@yourdomain.com>

# --- App --------------------------------------------------------------------
# REQUIRED in production. Set to your Vercel deployment URL (or custom domain).
# Used as the base URL in Supabase email confirmation links (emailRedirectTo).
# Example: https://your-app.vercel.app  or  https://app.detectivepulse.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Traccar (GPS903 integration) ------------------------------------------
# Shared secret for the Traccar webhook. Set the same value in Traccar's
# notification URL: https://your-app.com/api/webhooks/traccar?secret=<value>
# Generate with: openssl rand -hex 24
# Leave blank to disable webhook auth (not recommended for production).
TRACCAR_WEBHOOK_SECRET=your-traccar-webhook-secret

# --- GPS903 Web API Polling -------------------------------------------------
# GPS903 uses IMEI No. login (not Account login).
# GPS903_IMEI      = the 15-digit IMEI of the device used to log in
# GPS903_DEVICE_PASSWORD = the device password set in the GPS903 portal
GPS903_IMEI=your-device-imei-15-digits
GPS903_DEVICE_PASSWORD=your-device-password

# --- Marketing site analytics (Google Tag Manager) --------------------------
# Optional. Loads GTM only on the marketing host (detectivepulse.com) — inert
# elsewhere. Configure GA4 / Google Ads conversion / Meta Pixel tags inside the
# GTM container itself (no further code changes needed). The lead form fires a
# `lead_submitted` dataLayer event on success for a conversion trigger.
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# --- Vercel Cron authentication ---------------------------------------------
# Vercel passes this as: Authorization: Bearer <CRON_SECRET>
# Set the same value in your Vercel project env vars.
# Generate with: openssl rand -hex 24
CRON_SECRET=your-cron-secret
